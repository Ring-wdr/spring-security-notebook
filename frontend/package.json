{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:components": "vitest run --config vitest.components.config.ts",
    "test:watch": "vitest",
    "gen:api": "openapi-generator-cli generate -c openapi-generator.config.json --global-property=modelDocs=false,modelTests=false,apiDocs=false,apiTests=false --openapi-generator-ignore-list README.md,package.json,tsconfig.json,tsconfig.esm.json,.npmignore,docs/** --minimal-update"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.31.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.0",
    "msw": "^2.13.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
